{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "nest build",
    "start": "tsx src/main.ts",
    "start:debug": "tsx watch --inspect src/main.ts",
    "start:prod": "node dist/apps/api/src/main.js",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@repo/api": "workspace:*",
    "pg": "^8.16.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^5.0.3",
    "@types/pg": "^8.15.6",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "catalog:",
    "vitest": "^4.0.15"
  }
}
