  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@repo/typescript-config": "workspace:*",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "lefthook": "^2.0.4",
    "sherif": "^1.9.0",
    "turbo": "^2.6.1"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.24.0",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
